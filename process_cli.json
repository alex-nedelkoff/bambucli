{
    "type": "process",
    "from": "User",
    "name": "Makerspace CLI Overlay",
    "compatible_printers": [
        "Bambu Lab X1 Carbon 0.4 nozzle"
    ],
    "enable_support": "1",
    "support_type": "tree(auto)",
    "exclude_object": "1",
    "sparse_infill_density": "15%",
    "sparse_infill_pattern": "grid",
    "brim_type": "no_brim",
    "layer_change_gcode": "G92 E0\n; layer num/total_layer_count: {layer_num+1}/[total_layer_count]\n"
}
